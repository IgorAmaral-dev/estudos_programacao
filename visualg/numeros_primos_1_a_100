Algoritmo "NumerosPrimos1a100"
// Descrição   : Apresenta os números primos entre 1 e 100 e apresenta produto deles.
// Autor(a)    : Igor Amaral
// Data atual  : 24/05/2026
Var
varContador, i, n: inteiro
varNum: vetor[1..99] de inteiro
varProduto: real


Inicio
varProduto := 1
para i de 2 ate 100 faca
se (i = 2) ou (i = 3) ou (i = 5) ou (i =7) ou ((i%2)<>0) e ((i%3)<>0) e ((i%5)<>0) e ((i%7)<>0) entao
varContador := varContador + 1
varNum[varContador] := i
varProduto := varProduto * varNum[varContador]
fimse
fimpara
para i de 1 ate varContador faca
escreva (varNum[i]: 2, " ")
se (i%10 = 0) entao
escreval(" ")
fimse
fimpara
escreval("")
escreval("O total de números primos é de ", varContador)
escreval("O produto dos números é de ", varProduto:1:0)

Fimalgoritmo
