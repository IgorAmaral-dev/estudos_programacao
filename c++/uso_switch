#include <stdio.h>
#include <locale.h>
int main (){
	setlocale(LC_ALL,"");
	printf("Informe o salário base: R$\n");
	float salario, IRPF, AliqEf;
	int oSalario;
	scanf("%f", &salario);
	oSalario = (int)(salario*100);
	switch (oSalario){
		case 0 ... 190398:
			printf("Esse contribuinte é isento!\n");
			printf("Portanto não pagará nada de IMPOSTO DE RENDA.\n");
			printf("\n Nesse caso, a alícota efetiva dele será de 0%%.");
			break;
		case 190399 ... 282665:
			printf("Esse contribuinte pagará a alícota de 7,5%%\n");
			IRPF = salario * 0.075 - 142.8;
			printf("Imposto a pagar = R$ %.2f", IRPF);
			AliqEf = IRPF / salario * 100;
			printf("\nA alícota efetiva dele será de %.4f%%", AliqEf);
			break;
		case 282666 ... 375105:
			printf("Esse contribuinte pagará a alícota de 15%%\n");
			IRPF = salario * 0.15 - 354.8;
			printf("Imposto a pagar = R$ %.2f", IRPF);
			AliqEf = IRPF / salario * 100;
			printf("\nA alícota efetiva dele será de %.4f%%", AliqEf);
			break;
		case 375106 ... 466468:
		    printf("Esse contribuinte pagará a alícota de 22,5%%\n");
			IRPF = salario * 0.225 - 636.13;
			printf("Imposto a pagar = R$ %.2f", IRPF);
			AliqEf = IRPF / salario * 100;
			printf("\nA alícota efetiva dele será de %.4f%%", AliqEf);
			break;	
		default:
			printf("Esse contribuinte pagará a alícota de 27,5%%\n");
			IRPF = salario * 0.275 - 869.36;
			printf("Imposto a pagar = R$ %.2f", IRPF);
			AliqEf = IRPF / salario * 100;
			printf("\nA alícota efetiva dele será de %.4f%%", AliqEf);
	}
	if(IRPF<10 && IRPF>0){
		printf("\n Como o menor valor para DARF é de R% 10, o contribuinte não pagará.\n");
		printf("\nFica para o próximo mês. Porém, se for empregado de empresa\n");
		printf("\nsofrerá o desconto de R$ %.2f no seu contracheque", IRPF);
	}
}
